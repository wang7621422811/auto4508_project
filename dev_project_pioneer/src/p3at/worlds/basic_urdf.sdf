<?xml version="1.0" ?>
<sdf version="1.8">
    <world name="james_oval_world">
        <physics name="1ms" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>
        <!-- 跑物理引擎（重力、刚体、关节约束等） -->
        <plugin
            filename="libgz-sim-physics-system"
            name="gz::sim::systems::Physics">
        </plugin>
        <!-- 处理 GUI/用户命令（例如拖动物体等交互）。 -->
        <plugin
            filename="libgz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
        </plugin>
        <!-- 把场景状态播给 GUI/客户端，才能在仿真里看到模型。 -->
        <plugin
            filename="libgz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
        </plugin>
        <!-- 让带 IMU 传感器的模型能按物理状态输出 IMU 数据。 -->
        <plugin filename="libgz-sim-imu-system"
                name="gz::sim::systems::Imu">
        </plugin>
        <!-- 让带传感器（例如相机）的模型能按物理状态输出传感器数据。 -->
        <plugin filename="libgz-sim-sensors-system.so"
                name="gz::sim::systems::Sensors">
        </plugin>
        <!-- 处理模型间的物理接触（碰撞检测、响应等）。 -->
        <plugin filename="libgz-sim-contact-system"
                name="gz::sim::systems::Contact">
        </plugin>

        <light type="directional" name="sun">
                <cast_shadows>true</cast_shadows>
                <pose>0 0 10 0 0 0</pose>
                <diffuse>0.8 0.8 0.8 1</diffuse>
                <specular>0.2 0.2 0.2 1</specular>
                <attenuation>
                    <range>1000</range>
                    <constant>0.9</constant>
                    <linear>0.01</linear>
                    <quadratic>0.001</quadratic>
                </attenuation>
                <direction>-0.5 0.1 -0.9</direction>
            </light>

            <model name="ground_plane">
                <static>true</static>
                <link name="link">
                    <collision name="collision">
                    <geometry>
                        <plane>
                        <normal>0 0 1</normal>
                        </plane>
                    </geometry>
                    </collision>
                    <visual name="visual">
                    <geometry>
                        <plane>
                        <normal>0 0 1</normal>
                        <size>22 22</size>
                        </plane>
                    </geometry>
                    <material>
                        <ambient>0.22 0.48 0.18 1</ambient>
                        <diffuse>0.28 0.55 0.22 1</diffuse>
                        <specular>0.12 0.12 0.12 1</specular>
                    </material>
                    </visual>
                </link>
            </model>

            <!-- James Oval: map ~150m x 125m (50m scale); field scaled 1/10 (~15m N-S x 12.5m E-W).
                 Obstacles use full-scale geometry for sensible LiDAR / avoidance vs Pioneer. -->

            <!-- Elliptical boundary (scaled field) -->
            <model name="oval_fence_00">
                <static>true</static>
                <pose>6.2402 0.4205 0.0175 0 0 1.6176</pose>
                <link name="link">
                    <visual name="v">
                        <geometry><box><size>0.8411 0.025 0.035</size></box></geometry>
                        <material>
                            <ambient>0.95 0.95 0.95 1</ambient>
                            <diffuse>0.9 0.9 0.88 1</diffuse>
                        </material>
                    </visual>
                    <collision name="c">
                        <geometry><box><size>0.8411 0.025 0.035</size></box></geometry>
